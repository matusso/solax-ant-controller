# Copy to /etc/solax-ant-controller.env and set permissions to 600.

SOLAX_TOKEN_ID=your-solax-token
SOLAX_WIFI_SN=your-solax-wifi-sn
BRAIINS_BASE_URL=http://192.168.1.1
BRAIINS_USERNAME=root
BRAIINS_PASSWORD=your-password

# Optional runtime settings.
SOLAX_LOG_LEVEL=INFO
SOLAX_LOG_FILE=/var/log/solax-ant-controller/controller.jsonl
SOLAX_POLL_INTERVAL=300

# Set this to true while validating the daemon without changing miner state.
MINER_DRY_RUN=false
